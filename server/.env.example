PORT=8080
CRON_SECRET=replace-with-a-long-random-secret
GOOGLE_CLOUD_PROJECT=your-firebase-project-id
SUPPORT_EMAIL=support@example.com

# Configure at least one AI provider. Cloudflare is tried first when configured.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_MODELS=@cf/google/gemma-4-26b-a4b-it,@cf/zai-org/glm-4.7-flash
OPENROUTER_API_KEY=
OPENROUTER_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-super-120b-a12b:free,google/gemma-4-26b-a4b-it:free,z-ai/glm-4.5-air:free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.6-flash
MAX_AI_ARTICLES_PER_RUN=1
MAX_AI_ARTICLES_PER_DAY=50
MAX_CANDIDATES_PER_RUN=25

# Optional extra collectors. RSS and Telegram collectors work without these.
GNEWS_API_KEY=
NEWS_API_KEY=
